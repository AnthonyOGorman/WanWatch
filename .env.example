# Required
ADMIN_PASSWORD=change-me
COOKIE_SECRET=change-me-to-a-32-char-random-string
# Set to "false" if serving over plain HTTP (e.g. LAN test box/Raspberry Pi).
# Keep "true" when behind HTTPS/TLS.
COOKIE_SECURE=true

# Optional
DATABASE_URL="file:/app/data/wanwatch.db"
TZ=UTC

# API key for Bearer token access (min 16 chars). Optional — leave unset to disable.
# API_KEY=change-me-to-a-random-key
